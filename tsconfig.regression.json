{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": ".regression-dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/vite-env.d.ts",
    "src/types.ts",
    "src/data/sampleExam.ts",
    "src/data/templates.ts",
    "src/utils/archive.ts",
    "src/utils/backup.ts",
    "src/utils/calculations.ts",
    "src/utils/crypto.ts",
    "src/utils/exam.ts",
    "src/utils/export.ts",
    "src/utils/format.ts",
    "src/utils/grades.ts",
    "src/utils/reportFeedback.ts",
    "src/utils/sectionLinks.ts",
    "src/utils/storage.ts",
    "src/utils/studentDatabase.ts",
    "src/utils/students.ts",
    "src/utils/validation.ts",
    "src/utils/writing.ts",
    "src/utils/sectionWeights.ts"
  ]
}
