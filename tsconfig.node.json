{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "vite.config.ts",
    "tailwind.config.ts",
    "server/**/*.ts",
    "src/pdf/types.ts",
    "src/pdf/constants.ts",
    "src/pdf/privacy.ts"
  ]
}
